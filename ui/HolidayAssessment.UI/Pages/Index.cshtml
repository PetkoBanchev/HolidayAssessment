@page
@model IndexModel

<h1>Holiday Dashboard</h1>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<hr />

<form method="post" asp-page-handler="Import">

    <h3>Import Holidays</h3>
    
    <div class="mb-3">
        <label>Countries</label>
        <select asp-for="ImportCountries"
                asp-items="Model.CountryOptions"
                class="form-select"
                multiple>
        </select>
    </div>
    
    <div class="mb-3">
        <label>Year</label>
        <input asp-for="ImportYear" class="form-control" />
    </div>
    
    <div class="mb-3">
        <button class="btn btn-primary">Import Holidays</button>
    </div>
</form>

<hr />

<form method="get" asp-page-handler="LastThree">
    <h3>Last 3 Holidays</h3>
    
    <div class="mb-3">
        <label>Country</label>
        <select asp-for="LastThreeCountry" asp-items="Model.CountryOptions"></select>
    </div>
    
    <div class="mb-3">
        <button type="submit"
                name="handler"
                value="LastThree"
                class="btn btn-primary">
            Get last 3 holidays
        </button>
    </div>
    
    <table class="table table-bordered">
    <thead>
        <tr>
            <th>Date</th>
            <th>Name</th>
        </tr>
    </thead>
        <tbody>
            @if (Model.LastThreeHolidays != null && Model.LastThreeHolidays.Any())
            {
                foreach (var holiday in Model.LastThreeHolidays)
                {
                    <tr>
                        <td>@holiday.Date</td>
                        <td>@holiday.Name</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2">No data loaded yet</td>
                </tr>
            }
        </tbody>
</table>
</form>

<hr />

<form method="post" asp-page-handler="WeekdayHolidays">
    <h3>Weekday Holidays (Use to verify the count)</h3>
    
    <div class="mb-3">
        <label>Countries</label>
        <select asp-for="WeekdayCountries"
                asp-items="Model.CountryOptions"
                class="form-select"
                multiple>
        </select>
    </div>
    
    <div class="mb-3">
        <label>Year</label>
        <input asp-for="WeekdayYear" class="form-control" />
    </div>
    
    <div class="mb-3">
        <button type="submit"
                name="handler"
                value="WeekdayHolidays"
                class="btn btn-primary">
            Get weekday holidays
        </button>
    </div>
    
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Name</th>
                <th>Country</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.WeekdayHolidays != null && Model.WeekdayHolidays.Any())
            {
                foreach (var holiday in Model.WeekdayHolidays)
                {
                    <tr>
                        <td>@holiday.Date</td>
                        <td>@holiday.Name</td>
                        <td>@holiday.CountryCode</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3">No data loaded yet</td>
                </tr>
            }
        </tbody>
    </table>
</form>

<hr />

<form method="post" asp-page-handler="WeekdayHolidaysCount">
    <h3>Weekday Holidays Count</h3>
    
    <div class="mb-3">
        <label>Countries</label>
        <select asp-for="CountCountries"
                asp-items="Model.CountryOptions"
                class="form-select"
                multiple>
        </select>
    </div>
    
    <div class="mb-3">
        <label>Year</label>
        <input asp-for="CountYear" class="form-control" />
    </div>
    
    <div class="mb-3">
        <button type="submit"
                name="handler"
                value="WeekdayHolidaysCount"
                class="btn btn-primary">
            Get weekday holidays count
        </button>
    </div>
    
    <table class="table table-bordered">
    <thead>
        <tr>
            <th>Country</th>
            <th>Count</th>
        </tr>
    </thead>
    <tbody>
            @if (Model.WeekdayHolidaysCount != null && Model.WeekdayHolidaysCount.Any())
        {
                foreach (var holiday in Model.WeekdayHolidaysCount)
            {
                <tr>
                    <td>@holiday.CountryCode</td>
                    <td>@holiday.Count</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3">No data loaded yet</td>
            </tr>
        }
    </tbody>
</table>
</form>

<hr />

<form method="get" asp-page-handler="SharedHolidays">
    <h3>Shared Holidays</h3>
    
    <div class="mb-3">
        <label>Country</label>
        <select asp-for="CountryA" asp-items="Model.CountryOptions"></select>
    </div>
    
    <div class="mb-3">
        <label>Country</label>
        <select asp-for="CountryB" asp-items="Model.CountryOptions"></select>
    </div>
    
    <div class="mb-3">
        <label>Year</label>
        <input asp-for="SharedYear" class="form-control" />
    </div>
    
    <div class="mb-3">
        <button type="submit"
                name="handler"
                value="SharedHolidays"
                class="btn btn-primary">
            Get shared holidays
        </button>
    </div>
    
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Local Name A</th>
                <th>Local Name B</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.SharedHolidays != null && Model.SharedHolidays.Any())
            {
                foreach (var holiday in Model.SharedHolidays)
                {
                    <tr>
                        <td>@holiday.Date</td>
                        <td>@holiday.LocalNameA</td>
                        <td>@holiday.LocalNameB</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2">No data loaded yet</td>
                </tr>
            }
        </tbody>
    </table>
</form>